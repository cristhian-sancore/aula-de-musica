generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TEACHER
  STUDENT
}

enum EnrollmentStatus {
  PENDING_PAYMENT
  ACTIVE
  INACTIVE
}

enum LinkStatus {
  ACTIVE
  USED
  INACTIVE
}

enum ClassScheduleStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  JUSTIFIED
  LATE
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  whatsapp  String? // Optional for teacher, required for student usually
  image     String?  @db.Text // Profile picture URL or Base64
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Teacher relationships
  taughtModules  Module[]          @relation("TeacherModules")
  customLinks    CustomLink[]      @relation("TeacherLinks")
  settings       TeacherSettings?
  teacherLessons VideoLesson[]     @relation("TeacherLessons")

  // Student relationships
  enrollments Enrollment[]     @relation("StudentEnrollments")
  progresses  LessonProgress[] @relation("StudentProgress")
  messages    LessonMessage[]  @relation("StudentMessages")
  
  // In-person relationships
  schedulesAsTeacher ClassSchedule[] @relation("TeacherSchedules")
  schedulesAsStudent ClassSchedule[] @relation("StudentSchedules")
  invoices           Invoice[]       @relation("StudentInvoices")
}

model TeacherSettings {
  id                    String   @id @default(uuid())
  teacherId             String   @unique
  teacher               User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  cardTaxRate           Float    @default(0)
  enrollmentFee         Float    @default(90.00)
  defaultInstruments    String[] @default(["Violão", "Teclado", "Guitarra", "Baixo", "Bateria", "Canto"])
  defaultPaymentMethods String[] @default(["PIX", "Cartão de Crédito", "Boleto"])
  platformName          String   @default("Aula de Música")
  showPriceAsMonthly    Boolean  @default(false) // Se true, exibe R$ X/mês nos cards de plano
  sumEnrollmentFee      Boolean  @default(true) // Se false, a taxa de matrícula não será somada ao valor final, apenas informada
  availableSlots        Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Module {
  id          String   @id @default(uuid())
  title       String
  description String?
  price       Float
  isMonthly      Boolean  @default(false)
  durationMonths Int?     // Quantidade de meses/parcelas do plano (null = auto-detectar pelo nome)
  paymentMethods String[] @default([])
  teacherId      String
  teacher     User     @relation("TeacherModules", fields: [teacherId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons           VideoLesson[]
  enrollments       Enrollment[]
  customLinkModules CustomLinkModule[]
}

model VideoLesson {
  id         String   @id @default(uuid())
  title      String
  videoUrl   String // Expected to be a YouTube ID or embed URL
  order      Int      @default(0)
  moduleId   String?
  module     Module?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  teacherId  String?
  teacher    User?    @relation("TeacherLessons", fields: [teacherId], references: [id], onDelete: Cascade)
  instrument String? // Ex: "Violão", "Teclado", etc.
  chapter    String? // Ex: "Introdução", "Básico 1", "Básico 2", "Avançado 1"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  progresses LessonProgress[]
  messages   LessonMessage[]
}

model LessonProgress {
  id          String   @id @default(uuid())
  studentId   String
  lessonId    String
  completedAt DateTime @default(now())

  student User        @relation("StudentProgress", fields: [studentId], references: [id], onDelete: Cascade)
  lesson  VideoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
}

model LessonMessage {
  id        String    @id @default(uuid())
  studentId String
  lessonId  String
  content   String
  reply     String?
  createdAt DateTime  @default(now())
  repliedAt DateTime?

  student User        @relation("StudentMessages", fields: [studentId], references: [id], onDelete: Cascade)
  lesson  VideoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model CustomLink {
  id          String     @id @default(uuid())
  token       String     @unique @default(uuid()) // The unique part of the URL
  studentName String? // The expected student this link is for (optional, for reference)
  teacherId   String
  teacher     User       @relation("TeacherLinks", fields: [teacherId], references: [id])
  status      LinkStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  instruments    String[] @default([])
  paymentMethods String[] @default([])

  modules CustomLinkModule[]
}

model CustomLinkModule {
  id           String     @id @default(uuid())
  customLinkId String
  moduleId     String
  customLink   CustomLink @relation(fields: [customLinkId], references: [id], onDelete: Cascade)
  module       Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([customLinkId, moduleId])
}

model Enrollment {
  id            String  @id @default(uuid())
  studentId     String
  moduleId      String
  instrument    String?
  paymentMethod String?
  installments  Int?    @default(1)

  responsavel String?
  horario     String? // Dia e horário escolhidos (texto livre legado)
  cidade      String?
  conheceu    String?
  observacoes String?

  // Campos para gestão presencial
  dueDay             Int?    // Dia de vencimento da mensalidade (1-31)
  dayOfWeek          Int?    // Dia da semana (0=Dom, 1=Seg, ..., 6=Sáb)
  classTime          String? // Horário no formato "HH:mm" (Ex: "14:00")
  replacementCredits Int     @default(0) // Créditos para reposição de faltas justificadas

  status    EnrollmentStatus @default(PENDING_PAYMENT)
  student   User             @relation("StudentEnrollments", fields: [studentId], references: [id])
  module    Module           @relation(fields: [moduleId], references: [id])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([studentId, moduleId])
}

model ClassSchedule {
  id        String              @id @default(uuid())
  teacherId String
  studentId String
  date      DateTime            // Data e hora exata da aula agendada
  status    ClassScheduleStatus @default(SCHEDULED)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  teacher   User        @relation("TeacherSchedules", fields: [teacherId], references: [id])
  student   User        @relation("StudentSchedules", fields: [studentId], references: [id])
  attendance Attendance?
}

model Attendance {
  id              String           @id @default(uuid())
  classScheduleId String           @unique
  status          AttendanceStatus @default(PRESENT)
  observation     String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  classSchedule   ClassSchedule    @relation(fields: [classScheduleId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String        @id @default(uuid())
  studentId   String
  amount      Float
  dueDate     DateTime
  month       Int
  year        Int
  status      InvoiceStatus @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  student     User          @relation("StudentInvoices", fields: [studentId], references: [id], onDelete: Cascade)
}
